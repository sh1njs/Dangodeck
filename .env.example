# Server port (default: 3000)
PORT=3000

# Redis connection URL (optional — falls back to in-memory cache if not set)
# REDIS_URL=redis://localhost:6379

# Public site URL — used by Swagger/OpenAPI docs as the server base URL
# Development:  http://localhost:3000
# Production:   https://yourdomain.com
SITE_URL=http://localhost:3000

# Card data source (default: cloud)
#   cloud = raw GitHub (MochiiLabs), with local snapshot as fallback
#   local = read only src/data/cards.json, no network
CARDS_SOURCE=cloud