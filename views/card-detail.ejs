<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container page detail">
  <a href="/cards" class="nb-btn back-btn"><%- icon('arrow-left', { size: 16 }) %> Back to catalog</a>

  <div class="detail-grid">
    <div class="nb-card detail-image">
      <div class="detail-thumb">
        <img src="<%= card.image %>" alt="<%= card.name %>" />
      </div>
      <div class="detail-image-foot">
        <span class="nb-tag" style="background: <%= elementColor(card.element) %>; color:#1a1a1a;"><%= card.element %></span>
        <span class="mono text-muted">#<%= card.id %></span>
      </div>
    </div>

    <div class="detail-main">
      <h1 class="detail-name"><%= card.name %></h1>
      <p class="detail-anime text-muted"><%= card.anime %></p>
      <% if (card.lastPatch) { %>
      <span class="nb-tag tag-accent detail-patch">Latest patch</span>
      <% } %>

      <div class="nb-card detail-block">
        <div class="block-head-row">
          <h2 class="block-head">Stats</h2>
          <span class="stat-mult-badge mono" data-stat-mult hidden></span>
        </div>
        <div class="stat-bars" data-stat-bars data-element-color="<%= elementColor(card.element) %>">
          <% [
            { key: 'hp', label: 'HP' },
            { key: 'atk', label: 'ATK' },
            { key: 'def', label: 'DEF' },
            { key: 'spd', label: 'SPD' }
          ].forEach(function (s) { %>
          <div class="stat-bar-row" data-stat-row="<%= s.key %>">
            <span class="stat-bar-label mono"><%= s.label %></span>
            <div class="stat-bar-track">
              <div class="stat-bar-fill" data-stat-fill style="width: <%= (card.stats[s.key] / max) * 100 %>%; background: <%= elementColor(card.element) %>;"></div>
            </div>
            <span class="stat-bar-value mono" data-stat-value><%= card.stats[s.key] %></span>
            <span class="stat-bar-base mono text-muted" data-stat-base hidden></span>
          </div>
          <% }) %>
        </div>

        <div class="stat-calc" data-stat-calc>
          <div class="stat-calc-row">
            <span class="stat-calc-label mono">Rarity</span>
            <div class="stat-calc-chips" data-rarity-chips>
              <% statConfig.rarities.forEach(function (r) { %>
              <button type="button" class="nb-chip <%= r.key === statConfig.defaults.rarity ? 'is-active' : '' %>" data-rarity="<%= r.key %>"><%= r.label %></button>
              <% }) %>
            </div>
          </div>

          <div class="stat-calc-row">
            <span class="stat-calc-label mono">Level <strong data-level-out><%= statConfig.defaults.level %></strong></span>
            <input class="stat-calc-slider" type="range" min="<%= statConfig.level.min %>" max="<%= statConfig.level.max %>" value="<%= statConfig.defaults.level %>" data-level-input />
          </div>

          <div class="stat-calc-row">
            <span class="stat-calc-label mono">Evolution</span>
            <div class="stat-calc-chips" data-evo-chips>
              <% for (var e = statConfig.evo.min; e <= statConfig.evo.max; e++) { %>
              <button type="button" class="nb-chip <%= e === statConfig.defaults.evo ? 'is-active' : '' %>" data-evo="<%= e %>">Evo <%= e %></button>
              <% } %>
            </div>
          </div>

          <div class="stat-calc-row">
            <span class="stat-calc-label mono">Ascension</span>
            <div class="stat-calc-chips" data-asc-chips>
              <% for (var a = statConfig.ascension.min; a <= statConfig.ascension.max; a++) { %>
              <button type="button" class="nb-chip <%= a === statConfig.defaults.ascension ? 'is-active' : '' %>" data-asc="<%= a %>"><%= a === 0 ? 'None' : 'A' + a %></button>
              <% } %>
            </div>
          </div>

          <div class="stat-calc-actions">
            <button type="button" class="nb-btn" data-stat-roll><%- icon('zap', { size: 16 }) %> Roll random</button>
            <button type="button" class="nb-btn" data-stat-reset>Reset to base</button>
          </div>
        </div>
      </div>

      <div class="nb-card detail-block">
        <div class="block-head-row">
          <%- icon('sparkles', { size: 16 }) %>
          <h2 class="block-head">Talent</h2>
        </div>
        <h3 class="talent-name"><%= card.talent.name %></h3>
        <p class="text-muted talent-desc"><%= card.talent.description %></p>
      </div>
    </div>
  </div>

  <% if (related && related.length) { %>
  <section class="section">
    <h2 class="section-title">Related cards</h2>
    <p class="text-muted">More from <%= card.anime %> and the <%= card.element %> element.</p>
    <div class="card-grid related-grid">
      <% related.forEach(function (rc) { %>
        <%- include('partials/card-tile', { card: rc }) %>
      <% }) %>
    </div>
  </section>
  <% } %>
</div>

<script id="stat-config" type="application/json"><%- JSON.stringify(statConfig) %></script>
<script id="base-stats" type="application/json"><%- JSON.stringify(card.stats) %></script>
<%- include('partials/footer', { pageScript: 'card-detail.js' }) %>
