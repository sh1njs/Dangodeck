<a href="/cards/<%= card.id %>" class="card-tile">
  <div class="card-thumb">
    <img src="<%= card.image %>" alt="<%= card.name %>" loading="lazy" />
    <span class="nb-tag tile-element" style="background: <%= elementColor(card.element) %>; color:#1a1a1a;">
      <%= card.element %>
    </span>
    <% if (card.lastPatch) { %>
    <span class="nb-tag tile-new">New</span>
    <% } %>
  </div>
  <div class="card-body">
    <div class="card-title-row">
      <h3 class="card-name"><%= card.name %></h3>
      <span class="mono text-muted card-id">#<%= card.id %></span>
    </div>
    <p class="card-anime text-muted"><%= card.anime %></p>
    <div class="card-stats">
      <span class="stat-chip">HP <%= card.stats.hp %></span>
      <span class="stat-chip">AT <%= card.stats.atk %></span>
      <span class="stat-chip">DF <%= card.stats.def %></span>
      <span class="stat-chip">SP <%= card.stats.spd %></span>
    </div>
  </div>
</a>
