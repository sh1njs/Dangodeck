<%- include('partials/head') %>
<%- include('partials/header') %>

<div class="container page">
  <%- include('partials/page-header', {
    heading: 'Card Catalog',
    lead: 'Explore every card in the Dangodeck database. Fuzzy search, element & anime filters, and sorting.'
  }) %>

  <div class="browser" data-limit="<%= limit %>" data-total="<%= total %>" data-total-pages="<%= totalPages %>">
    <div class="browser-controls">
      <div class="search-wrap">
        <span class="search-icon"><%- icon('search', { size: 16 }) %></span>
        <input
          type="text"
          class="nb-input search-input"
          placeholder="Search cards (fuzzy: rem, reem, rme)…"
          data-search
        />
        <button type="button" class="search-clear" data-search-clear hidden aria-label="Clear">
          <%- icon('x', { size: 16 }) %>
        </button>
      </div>
      <button type="button" class="nb-btn" data-filter-toggle>
        <%- icon('sliders', { size: 16 }) %> Filters
        <span class="filter-dot" data-filter-dot hidden></span>
      </button>
    </div>

    <div class="nb-card filter-panel" data-filter-panel hidden>
      <label class="field">
        <span class="field-label">Element</span>
        <select class="nb-input" data-filter-element>
          <option value="">All elements</option>
          <% facets.elements.forEach(function (el) { %>
          <option value="<%= el %>"><%= el %></option>
          <% }) %>
        </select>
      </label>
      <label class="field">
        <span class="field-label">Anime</span>
        <select class="nb-input" data-filter-anime>
          <option value="">All anime</option>
          <% facets.animes.forEach(function (a) { %>
          <option value="<%= a %>"><%= a %></option>
          <% }) %>
        </select>
      </label>
      <label class="field">
        <span class="field-label">Sort</span>
        <select class="nb-input" data-filter-sort>
          <% sorts.forEach(function (s) { %>
          <option value="<%= s.value %>"><%= s.label %></option>
          <% }) %>
        </select>
      </label>
      <button type="button" class="nb-btn clear-filters" data-clear-filters hidden>
        <%- icon('x', { size: 16 }) %> Clear filters
      </button>
    </div>

    <p class="result-count text-muted" data-count><%= total %> cards</p>

    <div class="card-grid catalog-grid" data-grid>
      <% initialCards.forEach(function (card) { %>
        <%- include('partials/card-tile', { card: card }) %>
      <% }) %>
    </div>

    <div class="empty-state nb-card" data-empty hidden>
      <p class="empty-title">No cards found.</p>
      <p class="text-muted">Try a different search or clear your filters.</p>
    </div>

    <div class="loader" data-loader hidden><%- icon('zap', { size: 24 }) %> Loading…</div>
    <div class="sentinel" data-sentinel></div>
    <p class="end-note text-muted" data-end hidden></p>
  </div>
</div>

<script id="element-colors" type="application/json"><%- JSON.stringify(elementColors) %></script>
<%- include('partials/footer', { pageScript: 'cards.js' }) %>
